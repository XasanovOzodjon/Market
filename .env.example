# ═════════════════════════════════════════════════
# Market Project - Environment Variables
# ═════════════════════════════════════════════════

# ────────────────────────────────────────────────
# Django Settings
# ────────────────────────────────────────────────
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
SECRET_KEY=your-secret-key-here

# ────────────────────────────────────────────────
# Telegram Bot Settings
# ────────────────────────────────────────────────
BOT_TOKEN=your-bot-token-here
TELEGRAM_ADMINS=your-telegram-id

# ────────────────────────────────────────────────
# Server Settings
# ────────────────────────────────────────────────
IP=127.0.0.1

# Backend va Frontend URL lari
# Development:
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8000

# ────────────────────────────────────────────────
# Google OAuth Settings
# ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USER_INFO_URI=https://www.googleapis.com/oauth2/v2/userinfo
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://127.0.0.1:8000/api/auth/googleCallback

# ═════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT EXAMPLE
# ═════════════════════════════════════════════════
# Serverga deploy qilganda quyidagilarni o'zgartiring:
#
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,api.yourdomain.com
# SECRET_KEY=your-super-secure-random-secret-key-here
# IP=0.0.0.0
#
# # URLs - DIQQAT: https ishlatish kerak!
# BACKEND_URL=https://yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# 
# # Agar backend va frontend alohida domainlarda bo'lsa:
# # BACKEND_URL=https://api.yourdomain.com
# # FRONTEND_URL=https://yourdomain.com
#
# GOOGLE_REDIRECT_URL=https://yourdomain.com/api/auth/googleCallback
#
# ═════════════════════════════════════════════════
